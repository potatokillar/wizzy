#!/usr/bin/env bash

set -euo pipefail

if [[ "${WIZZY_ALLOW_UNDOCUMENTED:-0}" == "1" ]]; then
  exit 0
fi

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

if [[ -z "$staged_files" ]]; then
  exit 0
fi

if ! grep -q '^app/' <<<"$staged_files"; then
  exit 0
fi

if grep -q '^docs/' <<<"$staged_files"; then
  exit 0
fi

cat <<'EOF'
pre-commit: staged changes under app/ require staged documentation updates under docs/

Expected workflow:
1. Update the relevant design, plan, README, or other docs in docs/
2. Stage those doc changes
3. Commit again

If you intentionally need to bypass this once, run the commit with:
WIZZY_ALLOW_UNDOCUMENTED=1 git commit ...
EOF

exit 1
